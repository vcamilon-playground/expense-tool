NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Auth secret for JWT signing — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# AI_PROVIDER controls which model handles receipt OCR + insights.
# "groq"      -> Groq + Llama 4 Scout (vision) / Llama 3.3 70B (text). Free tier, no card. [default]
# "gemini"    -> Google Gemini 2.0 Flash. Free tier requires AI Studio auto-project.
# "anthropic" -> Claude Opus. Requires paid credits.
AI_PROVIDER=groq

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional fallbacks
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
