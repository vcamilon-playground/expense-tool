NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# AI_PROVIDER controls which model handles receipt OCR + insights.
# "gemini"   -> Google Gemini free tier (no credit card, 1500 req/day) [default]
# "anthropic" -> Claude (requires paid credits)
AI_PROVIDER=gemini

# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Optional, only needed if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
