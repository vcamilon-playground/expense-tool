# Copy to apps/web/.env.local and apps/mobile/.env (Expo prefix: EXPO_PUBLIC_)

# ---- Supabase (free tier, no auth) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ---- AI provider (default: gemini = free) ----
AI_PROVIDER=gemini
GOOGLE_API_KEY=AIza...            # https://aistudio.google.com/apikey (free)
ANTHROPIC_API_KEY=                # optional, only if AI_PROVIDER=anthropic

# ---- Mobile points at Next.js for AI calls ----
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
EXPO_PUBLIC_WEB_API_URL=http://localhost:3000
